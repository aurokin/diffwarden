{
  "name": "diffwarden",
  "version": "0.0.0",
  "private": true,
  "description": "A small CLI for agent-callable code review.",
  "type": "module",
  "bin": {
    "diffwarden": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sqlite3"]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.143",
    "@cursor/sdk": "^1.0.13",
    "@earendil-works/pi-coding-agent": "0.75.3",
    "commander": "^12.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
